{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/project-room-widget/codex_pet_hook.py\" --hook session_start",
            "statusMessage": "pet-studio: ready"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/project-room-widget/codex_pet_hook.py\" --hook user_prompt_submit",
            "statusMessage": "pet-studio: updating pet bubble"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/project-room-widget/codex_pet_hook.py\" --hook pre_tool_use"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/project-room-widget/codex_pet_hook.py\" --hook post_tool_use"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/project-room-widget/codex_pet_hook.py\" --hook pre_compact"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/project-room-widget/codex_pet_hook.py\" --hook stop"
          }
        ]
      }
    ]
  }
}
