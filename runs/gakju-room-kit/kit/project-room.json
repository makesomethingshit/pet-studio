{
  "schemaVersion": 1,
  "id": "project-room",
  "displayName": "Project Room",
  "description": "A side-view room-decorating kit for a Codex pet widget.",
  "styleLock": "style-lock.json",
  "cell": {
    "width": 192,
    "height": 208
  },
  "roomModule": {
    "width": 192,
    "height": 208,
    "perspective": "eye-level-side-view",
    "requiredFeatures": ["left-door", "right-door", "floor-line", "back-wall"],
    "safeArea": {
      "left": 10,
      "top": 12,
      "right": 182,
      "bottom": 198
    },
    "doorAnchors": {
      "left": {
        "x": 20,
        "y": 150
      },
      "right": {
        "x": 172,
        "y": 150
      }
    }
  },
  "atlas": {
    "columns": 8,
    "rows": 9,
    "width": 1536,
    "height": 1872
  },
  "layers": [
    {
      "id": "room",
      "role": "room",
      "path": "rooms/default-room.png",
      "z": 0,
      "anchor": "room"
    },
    {
      "id": "desk",
      "role": "prop",
      "path": "props/desk.png",
      "z": 10,
      "anchor": "desk"
    },
    {
      "id": "main-owner",
      "role": "mainPet",
      "path": "pets/main-owner/spritesheet.webp",
      "z": 20,
      "anchor": "owner"
    },
    {
      "id": "helper-reviewer",
      "role": "helperPet",
      "path": "pets/helper-reviewer/spritesheet.webp",
      "z": 18,
      "anchor": "helper",
      "visibleWhen": ["review"]
    }
  ],
  "anchors": {
    "cell-bottom-center": {
      "x": 96,
      "y": 190
    },
    "room": {
      "x": 96,
      "y": 208
    },
    "desk": {
      "x": 104,
      "y": 166
    },
    "owner": {
      "x": 70,
      "y": 170
    },
    "helper": {
      "x": 142,
      "y": 174
    }
  },
  "states": {
    "idle": {
      "mainPetRow": "idle",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "running-right": {
      "mainPetRow": "running-right",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "running-left": {
      "mainPetRow": "running-left",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "waving": {
      "mainPetRow": "waving",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "jumping": {
      "mainPetRow": "jumping",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "failed": {
      "mainPetRow": "failed",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "waiting": {
      "mainPetRow": "waiting",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "running": {
      "mainPetRow": "running",
      "visibleLayers": ["room", "desk", "main-owner"]
    },
    "review": {
      "mainPetRow": "review",
      "helperPetRow": "review",
      "visibleLayers": ["room", "desk", "helper-reviewer", "main-owner"]
    }
  }
}
